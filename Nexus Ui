    })
    Util.Round(btn, options.borderRadius)
    
    local xOffset = 10
    if options.icon then
        Util.Create("ImageLabel", {
            Parent = btn,
            Size = UDim2.new(0, 16, 0, 16),
            Position = UDim2.new(0, 10, 0.5, -8),
            BackgroundTransparency = 1,
            Image = Util.GetIcon(options.icon),
            ImageColor3 = options.textColor,
        })
        xOffset = 32
    end
    
    Util.Create("TextLabel", {
        Parent = btn,
        Size = UDim2.new(1, -xOffset - 5, 1, 0),
        Position = UDim2.new(0, xOffset, 0, 0),
        BackgroundTransparency = 1,
        Text = options.text,
        TextColor3 = options.textColor,
        Font = options.font,
        TextSize = options.textSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    -- Hover
    btn.MouseEnter:Connect(function()
        Util.Tween(btn, Util.TweenInfos.Fast, { BackgroundColor3 = theme.Accent })
    end)
    btn.MouseLeave:Connect(function()
        Util.Tween(btn, Util.TweenInfos.Fast, { BackgroundColor3 = options.backgroundColor })
    end)
    
    -- Click
    local originalSize = btn.Size
    btn.MouseButton1Down:Connect(function()
        Anim.PressDown(btn)
    end)
    btn.MouseButton1Up:Connect(function()
        Anim.PressUp(btn, originalSize)
        if options.callback then
            options.callback()
        end
    end)
    
    local api = {}
    function api:SetText(text) btn.TextLabel.Text = text end
    function api:Destroy() btn:Destroy() end
    return api
end

