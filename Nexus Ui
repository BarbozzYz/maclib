        textColor = theme.Text,
        textSize = theme.TextSize,
        font = theme.Font,
        layoutOrder = 0,
    }, options)
    
    local key = options.default
    local binding = false
    
    local frame = Util.Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, -10, 0, 32),
        BackgroundTransparency = 1,
        LayoutOrder = options.layoutOrder,
    })
    
    Util.Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(1, -85, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        BackgroundTransparency = 1,
        Text = options.text,
        TextColor3 = options.textColor,
        Font = options.font,
        TextSize = options.textSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    local keyBtn = Util.Create("TextButton", {
        Parent = frame,
        Size = UDim2.new(0, 70, 0, 24),
        Position = UDim2.new(1, -75, 0.5, -12),
        BackgroundColor3 = theme.Foreground,
        Text = key.Name,
        TextColor3 = theme.TextMuted,
        Font = theme.FontBold,
        TextSize = theme.SmallSize,
        AutoButtonColor = false,
    })
    Util.Round(keyBtn, 4)
    Util.Stroke(keyBtn, theme.Border, 0.5)
    
    keyBtn.MouseButton1Click:Connect(function()
        binding = true
        keyBtn.Text = "..."
        Util.Tween(keyBtn, Util.TweenInfos.Fast, { BackgroundColor3 = theme.Accent })
    end)
    
    UserInputService.InputBegan:Connect(function(input, gpe)
        if binding then
            if input.UserInputType == Enum.UserInputType.Keyboard then
                if input.KeyCode == Enum.KeyCode.Escape then
                    -- Cancel binding
                    binding = false
                    keyBtn.Text = key.Name
                    Util.Tween(keyBtn, Util.TweenInfos.Fast, { BackgroundColor3 = theme.Foreground })
                    return
                end
                key = input.KeyCode
                keyBtn.Text = key.Name
                binding = false
                Util.Tween(keyBtn, Util.TweenInfos.Fast, { BackgroundColor3 = theme.Foreground })
                if options.flag then Library.Flags[options.flag] = key end
                options.changedCallback(key)
            end
        elseif not gpe and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == key then
            options.callback(key)
        end
    end)
    
    if options.flag then Library.Flags[options.flag] = key end
    
    local api = {}
    function api:SetKey(newKey)
        key = newKey
        keyBtn.Text = key.Name
        if options.flag then Library.Flags[options.flag] = key end
    end
    function api:GetKey() return key end
    function api:Destroy() frame:Destroy() end
    return api
end

