local Util = {}

--- Create a Roblox Instance with properties
function Util.Create(className, properties)
    local instance = Instance.new(className)
    local parent = nil
    for key, value in pairs(properties) do
        if key == "Parent" then
            parent = value
        else
            instance[key] = value
        end
    end
    if parent then
        instance.Parent = parent
    end
    return instance
end

--- Shorthand tween
function Util.Tween(instance, tweenInfo, properties)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    tween:Play()
    return tween
end

--- Standard tween infos
Util.TweenInfos = {
    Fast = TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
    Normal = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
    Smooth = TweenInfo.new(0.35, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
    Slow = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
    Bounce = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
    Spring = TweenInfo.new(0.5, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out),
}

--- Lerp a Color3
function Util.LerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

--- Deep merge tables
function Util.Merge(base, override)
    local result = {}
    for k, v in pairs(base) do result[k] = v end
    if override then
        for k, v in pairs(override) do result[k] = v end
    end
    return result
end

--- Get icon asset ID from name
function Util.GetIcon(name)
    if not name then return "" end
    if typeof(name) == "string" and name:sub(1, 13) == "rbxassetid://" then
        return name
    end
    return Library.Icons[name] or Library.Icons.circle
end

--- Apply rounded corners
function Util.Round(instance, radius)
    return Util.Create("UICorner", {
        CornerRadius = UDim.new(0, radius or Library.CurrentTheme.CornerRadius),
        Parent = instance
    })
end

--- Apply stroke
function Util.Stroke(instance, color, transparency, thickness)
    return Util.Create("UIStroke", {
        Color = color or Library.CurrentTheme.Border,
        Transparency = transparency or 0.5,
        Thickness = thickness or 1,
        Parent = instance
    })
end

--- Apply padding
function Util.Pad(instance, top, right, bottom, left)
    return Util.Create("UIPadding", {
        PaddingTop = UDim.new(0, top or 0),
        PaddingRight = UDim.new(0, right or top or 0),
        PaddingBottom = UDim.new(0, bottom or top or 0),
        PaddingLeft = UDim.new(0, left or right or top or 0),
        Parent = instance
    })
end

--- Apply list layout
function Util.List(instance, padding, direction, alignment)
    return Util.Create("UIListLayout", {
        Padding = UDim.new(0, padding or 4),
        FillDirection = direction or Enum.FillDirection.Vertical,
        HorizontalAlignment = alignment or Enum.HorizontalAlignment.Center,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Parent = instance
    })
end

--- Apply gradient
function Util.Gradient(instance, colorA, colorB, rotation)
    return Util.Create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, colorA),
            ColorSequenceKeypoint.new(1, colorB)
        }),
        Rotation = rotation or 90,
        Parent = instance
    })
end

