        TextSize = theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    -- Active indicator bar
    local indicator = Util.Create("Frame", {
        Parent = tabBtn,
        Size = UDim2.new(0, 3, 0, 0),
        Position = UDim2.new(0, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = theme.Accent,
        BorderSizePixel = 0,
    })
    Util.Round(indicator, 2)
    
    -- Content page (scrollable)
    local page = Util.Create("ScrollingFrame", {
        Parent = contentArea,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Visible = false,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = theme.Border,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollingDirection = Enum.ScrollingDirection.Y,
    })
    local pageLayout = Util.List(page, 10)
    Util.Pad(page, 10, 10, 10, 10)
    
    -- Auto-resize canvas
    pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 25)
    end)
    
    -- Hover effects
    tabBtn.MouseEnter:Connect(function()
        if window.CurrentTab ~= Tab then
            Util.Tween(tabBtn, Util.TweenInfos.Fast, { BackgroundTransparency = 0.5 })
            Util.Tween(tabLabel, Util.TweenInfos.Fast, { TextColor3 = theme.TextSecondary })
        end
    end)
    tabBtn.MouseLeave:Connect(function()
        if window.CurrentTab ~= Tab then
            Util.Tween(tabBtn, Util.TweenInfos.Fast, { BackgroundTransparency = 1 })
            Util.Tween(tabLabel, Util.TweenInfos.Fast, { TextColor3 = theme.TextMuted })
        end
    end)
    
    function Tab:Select()
        -- Deselect current
        if window.CurrentTab and window.CurrentTab ~= Tab then
            local prev = window.CurrentTab
            prev.Page.Visible = false
            Util.Tween(prev.TabBtn, Util.TweenInfos.Normal, { BackgroundTransparency = 1 })
            Util.Tween(prev.TabLabel, Util.TweenInfos.Normal, { TextColor3 = theme.TextMuted })
            Util.Tween(prev.TabIcon, Util.TweenInfos.Normal, { ImageColor3 = theme.TextMuted })
            Util.Tween(prev.Indicator, Util.TweenInfos.Normal, { Size = UDim2.new(0, 3, 0, 0) })
        end
        
        -- Select this tab
        window.CurrentTab = Tab
        page.Visible = true
        Util.Tween(tabBtn, Util.TweenInfos.Normal, { BackgroundTransparency = 0 })
        Util.Tween(tabLabel, Util.TweenInfos.Normal, { TextColor3 = theme.Text })
        Util.Tween(tabIcon, Util.TweenInfos.Normal, { ImageColor3 = theme.Accent })
        Util.Tween(indicator, Util.TweenInfos.Normal, { Size = UDim2.new(0, 3, 0, 18) })
    end
    
    tabBtn.MouseButton1Click:Connect(function()
        Tab:Select()
    end)
    
    Tab.Page = page
    Tab.TabBtn = tabBtn
    Tab.TabLabel = tabLabel
    Tab.TabIcon = tabIcon
    Tab.Indicator = indicator
    
    -- Auto-select first tab
    if not window.CurrentTab then
        Tab:Select()
    end
    
    -- Section creation
    local sectionOrder = 0
    function Tab:CreateSection(opts)
        sectionOrder += 1
        opts = opts or {}
        opts.layoutOrder = sectionOrder
        local section = CreateSection(page, opts)
        table.insert(Tab.Sections, section)
        return section
    end
    
    return Tab
end

