local function CreateLabel(parent, options)
    local theme = Library.CurrentTheme
    options = Util.Merge({
        text = "Label",
        textColor = theme.TextSecondary,
        textSize = theme.SmallSize,
        font = theme.FontLight,
        icon = nil,
        padding = 0,
        layoutOrder = 0,
    }, options)
    
    local frame = Util.Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, -10, 0, 22),
        BackgroundTransparency = 1,
        LayoutOrder = options.layoutOrder,
    })
    
    local xOffset = 5
    if options.icon then
        Util.Create("ImageLabel", {
            Parent = frame,
            Size = UDim2.new(0, 14, 0, 14),
            Position = UDim2.new(0, 5, 0.5, -7),
            BackgroundTransparency = 1,
            Image = Util.GetIcon(options.icon),
            ImageColor3 = options.textColor,
        })
        xOffset = 25
    end
    
    local label = Util.Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(1, -xOffset, 1, 0),
        Position = UDim2.new(0, xOffset, 0, 0),
        BackgroundTransparency = 1,
        Text = options.text,
        TextColor3 = options.textColor,
        Font = options.font,
        TextSize = options.textSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
    })
    
    local api = {}
    function api:SetText(text)
        label.Text = text
    end
    function api:SetColor(color)
        label.TextColor3 = color
    end
    function api:Destroy()
        frame:Destroy()
    end
    return api
end

