local function CreateFillBar(parent, options)
    local theme = Library.CurrentTheme
    options = Util.Merge({
        text = "Progress",
        default = 0,
        min = 0,
        max = 1,
        suffix = "",
        callback = function() end,
        accentColor = theme.Accent,
        trackColor = theme.Active,
        textColor = theme.Text,
        textSize = theme.TextSize,
        font = theme.Font,
        height = 50,
        barHeight = 6,
        layoutOrder = 0,
    }, options)
    
    local value = options.default
    
    local frame = Util.Create("Frame", {
        Parent = parent,
        Size = UDim2.new(1, -10, 0, options.height),
        BackgroundTransparency = 1,
        LayoutOrder = options.layoutOrder,
    })
    
    -- Label row
    local labelText = Util.Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(0.7, 0, 0, 20),
        Position = UDim2.new(0, 5, 0, 2),
        BackgroundTransparency = 1,
        Text = options.text,
        TextColor3 = options.textColor,
        Font = options.font,
        TextSize = options.textSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    local valueLabel = Util.Create("TextLabel", {
        Parent = frame,
        Size = UDim2.new(0.3, -5, 0, 20),
        Position = UDim2.new(0.7, 0, 0, 2),
        BackgroundTransparency = 1,
        Text = tostring(math.floor(value * 100)) .. "%" .. options.suffix,
        TextColor3 = theme.TextSecondary,
        Font = theme.FontLight,
        TextSize = theme.SmallSize,
        TextXAlignment = Enum.TextXAlignment.Right,
    })
    
    -- Track
    local track = Util.Create("Frame", {
        Parent = frame,
        Size = UDim2.new(1, -10, 0, options.barHeight),
        Position = UDim2.new(0, 5, 0, 28),
        BackgroundColor3 = options.trackColor,
    })
    Util.Round(track, options.barHeight / 2)
    
    -- Fill
    local fill = Util.Create("Frame", {
        Parent = track,
        Size = UDim2.new(math.clamp((value - options.min) / (options.max - options.min), 0, 1), 0, 1, 0),
        BackgroundColor3 = options.accentColor,
    })
    Util.Round(fill, options.barHeight / 2)
    
    -- Glow on fill
    Util.Create("Frame", {
        Parent = fill,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = options.accentColor,
        BackgroundTransparency = 0.5,
    })
    
    -- Interactive: click/drag to set value
    local function updateFromInput(input)
        local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        value = options.min + (options.max - options.min) * pos
        Util.Tween(fill, Util.TweenInfos.Fast, {
            Size = UDim2.new(pos, 0, 1, 0)
        })
        valueLabel.Text = tostring(math.floor(value * 100) / 100) .. options.suffix
        options.callback(value)
    end
    
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateFromInput(input)
            local moveConn, releaseConn
            moveConn = UserInputService.InputChanged:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseMovement then
                    updateFromInput(i)
                end
            end)
            releaseConn = UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    if moveConn then moveConn:Disconnect() end
                    if releaseConn then releaseConn:Disconnect() end
                end
            end)
        end
    end)
    
    local api = {}
    function api:SetValue(val)
        value = math.clamp(val, options.min, options.max)
        local pct = (value - options.min) / (options.max - options.min)
        Util.Tween(fill, Util.TweenInfos.Normal, {
            Size = UDim2.new(pct, 0, 1, 0)
        })
        valueLabel.Text = tostring(math.floor(value * 100) / 100) .. options.suffix
    end
    function api:GetValue() return value end
    function api:Destroy() frame:Destroy() end
    return api
end

