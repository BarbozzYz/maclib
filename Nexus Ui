-- ============================================================
-- // ANIMATION ENGINE
-- ============================================================
local Anim = {}

function Anim.FadeIn(instance, duration)
    instance.BackgroundTransparency = 1
    Util.Tween(instance, TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quart), {
        BackgroundTransparency = instance:GetAttribute("TargetTransparency") or 0
    })
end

function Anim.FadeOut(instance, duration)
    Util.Tween(instance, TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quart), {
        BackgroundTransparency = 1
    })
end

function Anim.SlideIn(instance, direction, duration)
    local offsets = {
        left = UDim2.new(-1, 0, 0, 0),
        right = UDim2.new(1, 0, 0, 0),
        up = UDim2.new(0, 0, -1, 0),
        down = UDim2.new(0, 0, 1, 0),
    }
    local target = instance.Position
    instance.Position = target + offsets[direction or "left"]
    Util.Tween(instance, TweenInfo.new(duration or 0.35, Enum.EasingStyle.Quart), {
        Position = target
    })
end

function Anim.ScaleIn(instance, duration)
    local targetSize = instance.Size
    instance.Size = UDim2.new(
        targetSize.X.Scale * 0.8, targetSize.X.Offset * 0.8,
        targetSize.Y.Scale * 0.8, targetSize.Y.Offset * 0.8
    )
    instance.BackgroundTransparency = 1
    Util.Tween(instance, TweenInfo.new(duration or 0.35, Enum.EasingStyle.Back), {
        Size = targetSize,
        BackgroundTransparency = instance:GetAttribute("TargetTransparency") or 0
    })
end

function Anim.ScaleOut(instance, duration, callback)
    local tween = Util.Tween(instance, TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quart), {
        Size = UDim2.new(
            instance.Size.X.Scale * 0.85, instance.Size.X.Offset * 0.85,
            instance.Size.Y.Scale * 0.85, instance.Size.Y.Offset * 0.85
        ),
        BackgroundTransparency = 1
    })
    if callback then tween.Completed:Connect(callback) end
    return tween
end

function Anim.PressDown(instance)
    Util.Tween(instance, Util.TweenInfos.Fast, {
        Size = UDim2.new(
            instance.Size.X.Scale, instance.Size.X.Offset - 4,
            instance.Size.Y.Scale, instance.Size.Y.Offset - 2
        )
    })
end

function Anim.PressUp(instance, originalSize)
    Util.Tween(instance, Util.TweenInfos.Fast, {
        Size = originalSize
    })
end

function Anim.Ripple(parent, position, color)
    local ripple = Util.Create("Frame", {
        Parent = parent,
        BackgroundColor3 = color or Library.CurrentTheme.Accent,
        BackgroundTransparency = 0.7,
        Position = UDim2.new(0, position.X - parent.AbsolutePosition.X, 0, position.Y - parent.AbsolutePosition.Y),
        Size = UDim2.new(0, 0, 0, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        ZIndex = 10
    })
    Util.Round(ripple, 9999)
    local maxSize = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2
    local tween = Util.Tween(ripple, TweenInfo.new(0.5, Enum.EasingStyle.Quart), {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1
    })
    tween.Completed:Connect(function()
        ripple:Destroy()
    end)
end

-- ============================================================
-- // DRAG SYSTEM
-- ============================================================
local function MakeDraggable(handle, window)
    local dragging = false
    local dragInput, dragStart, startPos
    
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = window.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or
           input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            Util.Tween(window, Util.TweenInfos.Fast, {
                Position = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + delta.X,
                    startPos.Y.Scale, startPos.Y.Offset + delta.Y
                )
            })
        end
    end)
end

-- ============================================================
-- // THEME API
-- ============================================================
function Library:SetTheme(themeData)
    if type(themeData) == "string" then
        -- Named theme
        if Library.Themes[themeData] then
            Library.CurrentTheme = Library.Themes[themeData]
        end
    elseif type(themeData) == "table" then
        -- Custom theme: merge with default
        Library.CurrentTheme = Util.Merge(Library.Themes.Default, themeData)
    end
    -- TODO: Propagate theme changes to existing elements
end

function Library:RegisterTheme(name, themeData)
    Library.Themes[name] = Util.Merge(Library.Themes.Default, themeData)
end

