-- ============================================================
function Library:CreateWindow(options)
    local theme = Library.CurrentTheme
    options = Util.Merge({
        Title = "Nexus UI",
        SubTitle = nil,
        Size = UDim2.new(0, 620, 0, 420),
        Position = UDim2.new(0.5, -310, 0.5, -210),
        SidebarWidth = 165,
        ToggleKey = Enum.KeyCode.RightShift,
    }, options)
    
    local Window = {
        Title = options.Title,
        Tabs = {},
        CurrentTab = nil,
        Minimized = false,
        Fullscreen = false,
    }
    
    Library.ToggleKey = options.ToggleKey
    
    -- ScreenGui
    local screenGui = Util.Create("ScreenGui", {
        Name = "NexusUI",
        Parent = CoreGui,
        IgnoreGuiInset = true,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        ResetOnSpawn = false,
    })
    Library.ScreenGui = screenGui
    
    -- Main window frame
    local mainFrame = Util.Create("Frame", {
        Name = "Window",
        Parent = screenGui,
        Size = options.Size,
        Position = options.Position,
        BackgroundColor3 = theme.Background,
        BackgroundTransparency = theme.BackgroundTransparency,
        ClipsDescendants = true,
    })
    Util.Round(mainFrame, theme.CornerRadius + 2)
    Util.Stroke(mainFrame, theme.Border, 0.4)
    Util.Shadow(mainFrame, 40, theme.Shadow, 0.5)
    
    -- Gradient overlay on main
    Util.Create("Frame", {
        Parent = mainFrame,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundColor3 = theme.Accent,
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex = 2,
    })
    
    -- =================== TOP BAR ===================
    local topBar = Util.Create("Frame", {
        Name = "TopBar",
        Parent = mainFrame,
        Size = UDim2.new(1, 0, 0, 42),
        BackgroundTransparency = 1,
    })
    
    -- Title
    local titleLabel = Util.Create("TextLabel", {
        Parent = topBar,
        Size = UDim2.new(1, -130, 1, 0),
        Position = UDim2.new(0, 16, 0, 0),
        BackgroundTransparency = 1,
        Text = options.Title,
        TextColor3 = theme.Text,
        Font = theme.FontBold,
        TextSize = theme.HeaderSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    if options.SubTitle then
        titleLabel.Size = UDim2.new(0, 0, 1, 0)
        titleLabel.AutomaticSize = Enum.AutomaticSize.X
        
        Util.Create("TextLabel", {
            Parent = topBar,
            Size = UDim2.new(0, 0, 1, 0),
            Position = UDim2.new(0, titleLabel.AbsoluteSize.X + 24, 0, 0),
            AutomaticSize = Enum.AutomaticSize.X,
            BackgroundTransparency = 1,
            Text = options.SubTitle,
            TextColor3 = theme.TextMuted,
            Font = theme.FontLight,
            TextSize = theme.SmallSize,
            TextXAlignment = Enum.TextXAlignment.Left,
        })
    end
    
    -- Window controls (right side)
    local controls = Util.Create("Frame", {
        Parent = topBar,
        Size = UDim2.new(0, 90, 0, 42),
        Position = UDim2.new(1, -95, 0, 0),
        BackgroundTransparency = 1,
    })
    
    local function createControlButton(iconName, posX, callback)
        local btn = Util.Create("ImageButton", {
            Parent = controls,
            Size = UDim2.new(0, 20, 0, 20),
            Position = UDim2.new(0, posX, 0.5, -10),
            BackgroundTransparency = 1,
            Image = Util.GetIcon(iconName),
            ImageColor3 = theme.TextMuted,
        })
        btn.MouseEnter:Connect(function()
            Util.Tween(btn, Util.TweenInfos.Fast, { ImageColor3 = theme.Text })
        end)
        btn.MouseLeave:Connect(function()
            Util.Tween(btn, Util.TweenInfos.Fast, { ImageColor3 = theme.TextMuted })
        end)
        btn.MouseButton1Click:Connect(callback)
        return btn
    end
    
    -- Minimize button
    local originalSize = options.Size
    createControlButton("minus", 5, function()
        Window.Minimized = not Window.Minimized
        if Window.Minimized then
            Util.Tween(mainFrame, Util.TweenInfos.Smooth, {
                Size = UDim2.new(0, originalSize.X.Offset, 0, 42)
            })
        else
            Util.Tween(mainFrame, Util.TweenInfos.Smooth, {
                Size = Window.Fullscreen and UDim2.new(1, 0, 1, 0) or originalSize
            })
        end
    end)
    
    -- Fullscreen button
    createControlButton("maximize", 35, function()
        if Window.Minimized then return end
        Window.Fullscreen = not Window.Fullscreen
        if Window.Fullscreen then
            Util.Tween(mainFrame, Util.TweenInfos.Smooth, {
                Size = UDim2.new(1, -20, 1, -20),
                Position = UDim2.new(0, 10, 0, 10)
            })
        else
            Util.Tween(mainFrame, Util.TweenInfos.Smooth, {
                Size = originalSize,
                Position = options.Position
            })
        end
    end)
    
    -- Close button
    createControlButton("x", 65, function()
        Anim.ScaleOut(mainFrame, 0.3, function()
            screenGui:Destroy()
        end)
    end)
    
    -- Separator under top bar
    Util.Create("Frame", {
        Parent = topBar,
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = theme.Border,
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
    })
    
    -- =================== SIDEBAR ===================
    local sidebar = Util.Create("Frame", {
        Parent = mainFrame,
        Size = UDim2.new(0, options.SidebarWidth, 1, -42),
        Position = UDim2.new(0, 0, 0, 42),
        BackgroundColor3 = theme.Foreground,
        BackgroundTransparency = 0.5,
    })
    
    -- Sidebar separator
    Util.Create("Frame", {
        Parent = sidebar,
        Size = UDim2.new(0, 1, 1, 0),
        Position = UDim2.new(1, -1, 0, 0),
        BackgroundColor3 = theme.Border,
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
    })
    
    local tabContainer = Util.Create("ScrollingFrame", {
        Parent = sidebar,
        Size = UDim2.new(1, 0, 1, -10),
        Position = UDim2.new(0, 0, 0, 5),
        BackgroundTransparency = 1,
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollingDirection = Enum.ScrollingDirection.Y,
    })
    local tabLayout = Util.List(tabContainer, 3)
    Util.Pad(tabContainer, 5, 6, 5, 6)
    
    tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabContainer.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 15)
    end)
    
    -- =================== CONTENT AREA ===================
    local contentArea = Util.Create("Frame", {
        Parent = mainFrame,
        Size = UDim2.new(1, -options.SidebarWidth, 1, -42),
        Position = UDim2.new(0, options.SidebarWidth, 0, 42),
        BackgroundTransparency = 1,
    })
    
    -- Draggable
    MakeDraggable(topBar, mainFrame)
    
    -- Open animation
    mainFrame:SetAttribute("TargetTransparency", theme.BackgroundTransparency)
    Anim.ScaleIn(mainFrame, 0.4)
    
    -- Toggle key
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == Library.ToggleKey then
            Library.Visible = not Library.Visible
            screenGui.Enabled = Library.Visible
        end
    end)
    
    -- Tab creation
    function Window:CreateTab(opts)
        local tab = CreateTab(Window, tabContainer, contentArea, opts or {})
        table.insert(Window.Tabs, tab)
        return tab
    end
    
    -- Destroy
    function Window:Destroy()
        Anim.ScaleOut(mainFrame, 0.3, function()
            screenGui:Destroy()
        end)
    end
    
    table.insert(Library.Windows, Window)
    return Window
end

