-- // NOTIFICATION SYSTEM (Bonus)
-- ============================================================
function Library:Notify(options)
    local theme = Library.CurrentTheme
    options = Util.Merge({
        Title = "Notification",
        Content = "",
        Duration = 3,
        Icon = "bell",
        Type = "info", -- info, success, warning, error
    }, options)
    
    if not Library.ScreenGui then return end
    
    local typeColors = {
        info = theme.Accent,
        success = theme.Success,
        warning = theme.Warning,
        error = theme.Error,
    }
    local accentColor = typeColors[options.Type] or theme.Accent
    
    -- Container
    local notifFrame = Util.Create("Frame", {
        Parent = Library.ScreenGui,
        Size = UDim2.new(0, 280, 0, 70),
        Position = UDim2.new(1, 0, 1, -80),
        AnchorPoint = Vector2.new(1, 1),
        BackgroundColor3 = theme.Foreground,
    })
    Util.Round(notifFrame, 8)
    Util.Stroke(notifFrame, accentColor, 0.5)
    Util.Shadow(notifFrame, 20)
    
    -- Accent bar
    Util.Create("Frame", {
        Parent = notifFrame,
        Size = UDim2.new(0, 3, 1, -10),
        Position = UDim2.new(0, 5, 0, 5),
        BackgroundColor3 = accentColor,
        BorderSizePixel = 0,
    })
    
    -- Icon
    Util.Create("ImageLabel", {
        Parent = notifFrame,
        Size = UDim2.new(0, 18, 0, 18),
        Position = UDim2.new(0, 16, 0, 12),
        BackgroundTransparency = 1,
        Image = Util.GetIcon(options.Icon),
        ImageColor3 = accentColor,
    })
    
    -- Title
    Util.Create("TextLabel", {
        Parent = notifFrame,
        Size = UDim2.new(1, -50, 0, 20),
        Position = UDim2.new(0, 40, 0, 8),
        BackgroundTransparency = 1,
        Text = options.Title,
        TextColor3 = theme.Text,
        Font = theme.FontBold,
        TextSize = theme.TextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    -- Content
    Util.Create("TextLabel", {
        Parent = notifFrame,
        Size = UDim2.new(1, -50, 0, 30),
        Position = UDim2.new(0, 40, 0, 30),
        BackgroundTransparency = 1,
        Text = options.Content,
        TextColor3 = theme.TextSecondary,
        Font = theme.FontLight,
        TextSize = theme.SmallSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
    })
    
    -- Slide in
    Util.Tween(notifFrame, Util.TweenInfos.Smooth, {
        Position = UDim2.new(1, -20, 1, -80)
    })
    
    -- Auto dismiss
    task.delay(options.Duration, function()
        local tween = Util.Tween(notifFrame, Util.TweenInfos.Normal, {
            Position = UDim2.new(1, 20, 1, -80),
            BackgroundTransparency = 1,
        })
        tween.Completed:Connect(function()
            notifFrame:Destroy()
        end)
    end)
end

-- ============================================================
-- // CLEANUP
-- ============================================================
function Library:Destroy()
    for _, window in ipairs(Library.Windows) do
        if window.Destroy then window:Destroy() end
    end
    Library.Windows = {}
    for _, conn in ipairs(Library.Connections) do
        if conn.Disconnect then conn:Disconnect() end
    end
    Library.Connections = {}
end

-- ============================================================
-- // RETURN
-- ============================================================
return Library

